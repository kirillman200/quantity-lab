{
  "name": "project-quantity-lab",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Product-neutral home project material, cost, and shopping-list calculators.",
  "homepage": "https://home.utilitas.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirillman200/Project-Quantity-Lab.git"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check && tsc --noEmit && wrangler types --check",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/calculations.test.ts tests/worker.test.ts",
    "test:site": "vitest run tests/site-contract.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node tests/run-e2e.mjs",
    "validate": "npm run check && npm run test:unit && npm run build && npm run test:site",
    "deploy:dry": "npm run build && wrangler deploy --dry-run",
    "deploy": "npm run validate && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/vue": "^7.0.1",
    "astro": "^7.1.3",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
