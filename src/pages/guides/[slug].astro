---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, absolute, calculatorBySlug, guides, type GuideDefinition } from '../../data/site';

export function getStaticPaths() {
  return guides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

interface Props { guide: GuideDefinition }
const { guide } = Astro.props;
const calculator = calculatorBySlug[guide.category];
const related = guides.filter((item) => item.category === guide.category && item.slug !== guide.slug).slice(0, 3);
const path = `/guides/${guide.slug}/`;
const jsonLd = [
  { '@type': 'TechArticle', headline: guide.title, description: guide.description, url: absolute(path), datePublished: SITE.updated, dateModified: SITE.updated, author: { '@id': `${SITE.origin}/#organization` }, publisher: { '@id': `${SITE.origin}/#organization` }, image: absolute('/images/share-card.png'), mainEntityOfPage: absolute(path) },
  { '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.origin },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: absolute('/guides/') },
    { '@type': 'ListItem', position: 3, name: guide.title, item: absolute(path) },
  ] },
];
---
<BaseLayout title={guide.title} description={guide.description} path={path} type="article" jsonLd={jsonLd}>
  <header class="page-hero"><div class="narrow"><nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span><a href="/guides/">Guides</a></span><span>{calculator.shortName}</span></nav><p class="eyebrow">{calculator.shortName} guide · {guide.readingTime}</p><h1>{guide.title}</h1><p class="lead">{guide.description}</p></div></header>
  <article class="section"><div class="shell content-grid">
    <div class="prose">
      <p class="lead">{guide.intro}</p>
      {guide.sections.map((section, index) => <><section><h2>{section.heading}</h2>{section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}{section.steps && <ol>{section.steps.map((step) => <li>{step}</li>)}</ol>}</section>{index === 0 && <div class="ad-slot compact print-hidden" aria-label="Reserved ad space"><span>Reserved ad space</span></div>}</>)}
      <div class="ad-slot print-hidden" aria-label="Reserved ad space"><span>Reserved ad space</span></div>
      <section><h2>Practical takeaway</h2><p>{guide.takeaway}</p></section>
      <div class="disclaimer"><strong>Planning note:</strong> Confirm product instructions, site conditions, safety requirements, and applicable local rules before purchasing or starting work.</div>
      {related.length > 0 && <section><h2>Related {calculator.shortName.toLowerCase()} guides</h2><div class="guide-grid">{related.map((item) => <a class="guide-card" href={`/guides/${item.slug}/`}><span class="meta"><span>Guide</span><span>{item.readingTime}</span></span><h3>{item.title}</h3><p>{item.description}</p></a>)}</div></section>}
    </div>
    <aside class="sidebar print-hidden"><div class="note-card"><h2>Put this into practice</h2><p>Use the guide’s method in the project planner, then save the inputs with the assumptions attached.</p><p><a class="button" href={`/calculators/${calculator.slug}/`}>Open {calculator.shortName} calculator</a></p></div><div class="note-card"><h2>Project data</h2><p>No account is required. Saved projects remain in this browser; sharing happens only when you create a link.</p></div></aside>
  </div></article>
</BaseLayout>
