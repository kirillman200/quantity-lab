---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, absolute } from '../data/site';
import { trustPages, type TrustPage } from '../data/trust';

export function getStaticPaths() { return trustPages.map((page) => ({ params: { trust: page.slug }, props: { page } })); }
interface Props { page: TrustPage }
const { page } = Astro.props;
const path = `/${page.slug}/`;
const lastReviewed = new Intl.DateTimeFormat('en-US', { dateStyle: 'long', timeZone: 'UTC' }).format(new Date(`${SITE.updated}T00:00:00Z`));
const jsonLd = [
  { '@type': 'WebPage', name: page.title, description: page.description, url: absolute(path), dateModified: SITE.updated },
  { '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE.origin }, { '@type': 'ListItem', position: 2, name: page.title, item: absolute(path) }] },
];
---
<BaseLayout title={page.title} description={page.description} path={path} jsonLd={jsonLd}>
  <header class="page-hero"><div class="narrow"><nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span>{page.title}</span></nav><p class="eyebrow">{page.eyebrow}</p><h1>{page.title}</h1><p class="lead">{page.intro}</p></div></header>
  <article class="section"><div class="narrow prose">{page.sections.map((section) => <section><h2>{section.heading}</h2>{section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}{section.bullets && <ul>{section.bullets.map((bullet) => <li>{bullet}</li>)}</ul>}{section.link && <p><a href={section.link.href}>{section.link.label}</a></p>}</section>)}<div class="disclaimer"><strong>Last reviewed:</strong> {lastReviewed}. Product functionality and disclosures should be reviewed whenever third-party services or data flows change.</div></div></article>
</BaseLayout>
